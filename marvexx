<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Marvexx Financial</title>
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
        font-family: Arial, sans-serif;
        background-color: #ffffff;
        color: #0B1F3F;
    }

    header {
        text-align: center;
        padding: 80px 20px 40px 20px;
        border-bottom: 2px solid #d3d3d3;
    }

    header img.logo {
        width: 250px;
        max-width: 80%;
        display: block;
        margin: 0 auto;
    }

    .hero {
        text-align: center;
        padding: 80px 20px;
        border-bottom: 2px solid #d3d3d3;
    }

    .hero h1 { font-size: 3rem; margin-bottom: 20px; }
    .hero p { font-size: 1.3rem; }

    .section {
        max-width: 1200px;
        margin: 0 auto;
        padding: 60px 20px;
    }

    .section h2 {
        text-align: center;
        margin-bottom: 40px;
        font-size: 2.2rem;
    }

    .services {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 30px;
    }

    .service-card {
        border: 1px solid #d3d3d3;
        padding: 25px;
        border-radius: 10px;
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .service-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 6px 15px rgba(0,0,0,0.1);
    }

    .service-card h3 { margin-bottom: 15px; font-size: 1.4rem; }
    .service-card p { font-size: 1rem; }

    .contact-form {
        max-width: 600px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .contact-form input,
    .contact-form textarea,
    .contact-form select {
        padding: 15px;
        border: 1px solid #d3d3d3;
        border-radius: 5px;
        font-size: 1rem;
    }

    .contact-form button {
        padding: 15px;
        font-size: 1rem;
        background-color: #0B1F3F;
        color: #ffffff;
        border: none;
        cursor: pointer;
        border-radius: 5px;
    }

    .contact-form button:hover { opacity: 0.9; }

    footer {
        text-align: center;
        padding: 30px 20px;
        border-top: 2px solid #d3d3d3;
        font-size: 0.9rem;
    }

    @media (max-width: 768px) {
        .hero h1 { font-size: 2rem; }
    }
</style>
</head>
<body>

<header>
    <img src="marvexx.png" alt="Marvexx Financial Logo" class="logo">
</header>

<section class="hero">
    <h1>Smart Financial Solutions. Trusted Guidance.</h1>
    <p>Your guidance to being compliant</p>
</section>

<section class="section" id="about">
    <h2>About Us</h2>
    <p style="text-align:center;">Founded in Stanislaus County</p>
    <p style="text-align:center;">Location: Modesto, CA</p>
</section>

<section class="section" id="services">
    <h2>Our Services</h2>
    <div class="services">
        <div class="service-card">
            <h3>Financial Accounting</h3>
            <p>Keeping your financial transactions</p>
            <p>in order with spreadsheets</p>
        </div>
        <div class="service-card">
            <h3>Financial Accounting Tools</h3>
            <p>Generating financial tools such</p>
            <p>as programs & softwares.</p>
        </div>
        <div class="service-card">
            <h3>Budgeting</h3>
            <p>Additional service to determine</p>
            <p>budgets for financial decisions.</p>
        </div>
    </div>
</section>

<section class="section" id="contact">
    <h2>Contact Us</h2>

    <form class="contact-form" action="https://formspree.io/f/xbdgeojg" method="POST">
        <input type="text" name="Name" placeholder="Full Name" required>

        <select name="ContactMethod" required>
            <option value="">Preferred Method</option>
            <option value="Call">Call</option>
            <option value="Text">Text</option>
        </select>

        <input type="tel" id="phone" name="Phone" placeholder="Phone Number" required>

        <textarea name="Message" rows="5" placeholder="Service Description"></textarea>

        <button type="submit">Send Message</button>
    </form>
</section>

<footer>
    &copy; 2026 Marvexx Financial. All rights reserved.
</footer>

<script>
    const phoneInput = document.getElementById('phone');

    phoneInput.addEventListener('blur', function(e) {
        // Remove non-numeric characters
        let x = this.value.replace(/\D/g,''); 
        // Only allow US numbers (10 digits)
        if(x.length !== 10){
            alert("Please enter a valid 10-digit US phone number.");
            this.value = '';
            return;
        }
        // Format number (2097076018 -> (209) 707-6018)
        this.value = `(${x.substring(0,3)}) ${x.substring(3,6)}-${x.substring(6,10)}`;
    });
</script>

</body>
</html>
